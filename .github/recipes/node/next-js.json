{
  "name": "Next.js App",
  "description": "Creates a new Next.js project dynamically.",
  "flags": {
    "typescript": "--ts",
    "javascript": "--js",
    "tailwind": "--tailwind",
    "eslint": "--eslint",
    "appRouter": "--app",
    "pagesRouter": "--no-app",
    "srcDir": "--src-dir",
    "empty": "--empty"
  },
  "commands": [
    {
      "command": "npx create-next-app@latest {{projectName}} {{flags}} --use-npm",
      "description": "Scaffold the Next.js project dynamically using native CLI flags."
    },
    {
      "command": "cd {{projectName}} && npm run build",
      "description": "Verify the project builds successfully."
    }
  ]
}
